{
  "name": "spyhunt",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "gen:config": "node ../../packages/core/build/make-app-json.js",
    "gen:icon": "node scripts/make-icon.js",
    "build:html": "node build.js",
    "test": "node tests/engine.spyhunt.test.js && node tests/ui.spyhunt.smoke.test.js",
    "start": "npm run gen:config && npm run build:html && expo start",
    "android": "npm run gen:config && npm run build:html && expo run:android",
    "build:android": "npm run gen:config && npm run gen:icon && npm run build:html && npx eas-cli@latest build -p android --profile preview"
  },
  "dependencies": {
    "@partydeck/core": "*",
    "expo": "^56.0.12",
    "expo-asset": "~56.0.17",
    "expo-file-system": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-webview": "14.0.1",
    "react-native-safe-area-context": "~5.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
