{
  "expo": {
    "name": "Alien",
    "slug": "alien",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#04121a",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#04121a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#04121a",
      "barStyle": "light-content"
    },
    "android": {
      "package": "com.partydeck.alien",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#04121a"
      }
    },
    "ios": {
      "bundleIdentifier": "com.partydeck.alien",
      "supportsTablet": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#04121a",
      "barStyle": "light-content"
    },
    "extra": {
      "eas": {
        "projectId": "d5819228-6ed6-459a-bc3b-b77af3492e13"
      }
    },
    "owner": "snyperdrydan"
  }
}
