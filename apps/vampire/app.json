{
  "expo": {
    "name": "Vampire",
    "slug": "vampire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#120407",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#120407"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#120407",
